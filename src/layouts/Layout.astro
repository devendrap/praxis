---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import { Font } from "astro:assets";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Learn to create value, not just earn a salary. AI-powered coaching that teaches you how the economy actually works." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-instrument-serif" preload />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    <script is:inline>
      if (localStorage.getItem("praxis-theme") === "light") {
        document.documentElement.classList.add("light");
      }
    </script>
  </head>
  <body class="min-h-screen">
    <Nav />
    <slot />
  </body>
</html>
