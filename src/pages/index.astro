---
import Layout from "../layouts/Layout.astro";
import Chat from "../components/Chat.tsx";
---

<Layout title="Praxis — Learn to Create Value">
  <div class="relative overflow-hidden">
    <!-- Hero -->
    <header class="relative px-6 pb-16 md:pb-24 max-w-5xl mx-auto">
      <div class="max-w-3xl">
        <h1 class="font-display text-5xl md:text-7xl leading-tight mb-6">
          Stop trading time.<br />
          <span class="italic text-ember">Start creating value.</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-light max-w-2xl leading-relaxed mb-10">
          The education system taught you to follow schedules, obey hierarchies, and wait for a
          paycheck. Praxis teaches you how the economy actually works — so AI becomes your
          leverage, not your replacement.
        </p>
        <a
          href="#coach"
          class="inline-flex items-center gap-2 bg-ember text-midnight font-semibold px-8 py-3.5 rounded-full hover:bg-ember-light transition-colors text-lg"
        >
          Talk to the Coach
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </header>

    <!-- What You'll Learn -->
    <section class="px-6 py-16 md:py-24 border-t border-slate-mid/30">
      <div class="max-w-5xl mx-auto">
        <h2 class="font-display text-3xl md:text-4xl mb-12 italic">
          What school never taught you
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-slate-deep/50 rounded-2xl p-8 border border-slate-mid/20">
            <div class="w-10 h-10 rounded-full bg-ember/10 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-ember" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-3">How Revenue Works</h3>
            <p class="text-slate-light leading-relaxed">
              Understand how businesses generate money, acquire customers, and create demand.
              Not theory — the mechanics that actually drive the economy.
            </p>
          </div>
          <div class="bg-slate-deep/50 rounded-2xl p-8 border border-slate-mid/20">
            <div class="w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-3">AI as Leverage</h3>
            <p class="text-slate-light leading-relaxed">
              Learn to use AI as a force multiplier for your ideas — not compete against it
              for tasks. The mindset shift that separates creators from the displaced.
            </p>
          </div>
          <div class="bg-slate-deep/50 rounded-2xl p-8 border border-slate-mid/20">
            <div class="w-10 h-10 rounded-full bg-ember/10 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-ember" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-3">Personal Brand</h3>
            <p class="text-slate-light leading-relaxed">
              Build your public identity around the value you create. Real humans aren't
              replaceable — but only if people know what you stand for.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- The Problem -->
    <section class="px-6 py-16 md:py-24 border-t border-slate-mid/30">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="font-display text-3xl md:text-4xl mb-6 italic">The broken mental model</h2>
          <p class="text-slate-light leading-relaxed mb-4">
            For generations, the path was clear: study hard, get a degree, land a job, earn a
            salary. That contract is breaking. AI doesn't replace people — it replaces tasks.
            And when tasks vanish, the time-for-money contract breaks with them.
          </p>
          <p class="text-slate-light leading-relaxed">
            The crisis isn't "AI vs jobs." It's industrial-age economic psychology colliding
            with exponential technology. Praxis helps you upgrade your mental model before
            the collision hits.
          </p>
        </div>
        <div class="bg-slate-deep/50 rounded-2xl p-8 border border-slate-mid/20 space-y-6">
          <div>
            <p class="text-sm font-medium text-slate-light/60 uppercase tracking-wider mb-2">Old model</p>
            <p class="text-lg line-through text-slate-light/40">Study &rarr; Degree &rarr; Job &rarr; Salary &rarr; Safety</p>
          </div>
          <div class="border-t border-slate-mid/30 pt-6">
            <p class="text-sm font-medium text-ember uppercase tracking-wider mb-2">Praxis model</p>
            <p class="text-lg text-ivory">Learn how value works &rarr; Create &rarr; Ship &rarr; Own &rarr; Leverage AI</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Coach Section -->
    <section id="coach" class="px-6 py-16 md:py-24 border-t border-slate-mid/30">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="font-display text-3xl md:text-4xl mb-4 italic">Your Value Creation Coach</h2>
          <p class="text-slate-light">
            An AI mentor that teaches you how the economy works — through conversation, not lectures.
            Ask anything about business, value creation, AI leverage, or building your path.
          </p>
        </div>
        <Chat client:load />
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-6 py-12 border-t border-slate-mid/30 text-center">
      <p class="font-display text-xl italic text-ember mb-2">Praxis</p>
      <p class="text-sm text-slate-light">
        Built on the research of
        <a href="https://www.linkedin.com/in/melissa-carleton-911499165/" class="text-ember hover:text-ember-light transition-colors">Melissa Carleton</a>
        — Princeton researcher and market analyst.
      </p>
    </footer>
  </div>
</Layout>
