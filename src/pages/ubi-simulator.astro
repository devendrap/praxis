---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import UBISimulator from "../components/UBISimulator.tsx";
---

<Layout title="UBI Policy Simulator — Praxis" description="Model Universal Basic Income scenarios and analyze them through the lens of power dynamics, equity, and sustainability.">
  <div class="relative overflow-hidden">
    <Nav />
    <header class="relative px-6 pb-10 md:pb-16 max-w-5xl mx-auto">

      <div class="max-w-3xl">
        <h1 class="font-display text-4xl md:text-6xl leading-tight mb-6">
          UBI Policy<br />
          <span class="italic text-ember">Simulator</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-light max-w-2xl leading-relaxed">
          Model Universal Basic Income scenarios and analyze them through the lens of power dynamics,
          equity, and sustainability — grounded in
          <a href="https://www.linkedin.com/in/melissa-carleton-911499165/" class="text-ember hover:text-ember-light transition-colors">Melissa Carleton</a>'s
          research on UBI in an AI-driven age.
        </p>
      </div>
    </header>

    <section class="px-6 pb-16 md:pb-24">
      <div class="max-w-5xl mx-auto">
        <UBISimulator client:load />
      </div>
    </section>

    <footer class="px-6 py-12 border-t border-slate-mid/30 text-center">
      <p class="font-display text-xl italic text-ember mb-2">Praxis</p>
      <p class="text-sm text-slate-light">
        Built on the research of
        <a href="https://www.linkedin.com/in/melissa-carleton-911499165/" class="text-ember hover:text-ember-light transition-colors">Melissa Carleton</a>
        at Princeton.
      </p>
    </footer>
  </div>
</Layout>
