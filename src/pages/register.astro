---
import Layout from "../layouts/Layout.astro";

const error = Astro.url.searchParams.get("error");

const errorMessages: Record<string, string> = {
  exists: "An account with that email already exists.",
  missing: "Please fill in all fields.",
  short: "Password must be at least 8 characters.",
  invalid: "Invalid input.",
};

const errorMessage = error ? errorMessages[error] ?? "Something went wrong." : null;

// Redirect if already logged in
if (Astro.locals.user) {
  return Astro.redirect("/");
}
---

<Layout title="Register — Praxis">
  <main class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <h1 class="font-display text-3xl italic text-ember mb-2">Register</h1>
      <p class="text-slate-light text-sm mb-8">Create an account to unlock all Praxis tools.</p>

      {errorMessage && (
        <div class="bg-red-500/10 border border-red-500/30 rounded-lg px-4 py-3 mb-6 text-red-400 text-sm">
          {errorMessage}
        </div>
      )}

      <form method="POST" action="/api/v1/auth/register" class="space-y-4">
        <div>
          <label for="email" class="block text-sm font-medium text-slate-light mb-1.5">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-slate-mid/30 bg-[var(--bg-secondary)] px-4 py-2.5 text-[var(--text-primary)] placeholder-slate-mid focus:outline-none focus:border-ember/50 focus:ring-1 focus:ring-ember/50"
            placeholder="you@example.com"
          />
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-slate-light mb-1.5">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="new-password"
            minlength="8"
            class="w-full rounded-lg border border-slate-mid/30 bg-[var(--bg-secondary)] px-4 py-2.5 text-[var(--text-primary)] placeholder-slate-mid focus:outline-none focus:border-ember/50 focus:ring-1 focus:ring-ember/50"
            placeholder="••••••••"
          />
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-ember px-4 py-2.5 text-sm font-semibold text-midnight hover:bg-ember-light transition-colors"
        >
          Create account
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-slate-light">
        Already have an account?
        <a href="/login" class="text-ember hover:text-ember-light transition-colors">Sign in</a>
      </p>
    </div>
  </main>
</Layout>
