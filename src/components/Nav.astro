---
import ThemeToggle from "./ThemeToggle.tsx";
import MobileMenu from "./MobileMenu.tsx";

interface Props {
  user?: { id: string; email: string };
}

const { user } = Astro.props;
const pathname = Astro.url.pathname;

const learnLinks = [
  { href: "/articles", label: "Articles" },
  { href: "/economics-lab", label: "Economics Lab" },
];

const toolLinks = [
  { href: "/degree-calculator", label: "Degree Calculator" },
  { href: "/ubi-simulator", label: "UBI Simulator" },
  { href: "/assess", label: "Assessment" },
];

const allLinks = [...learnLinks, ...toolLinks];

function isActive(href: string): boolean {
  return pathname === href || pathname === href + "/";
}

const mobileGroups = [
  { links: [{ href: "/", label: "Home" }, { href: "/#coach", label: "Coach" }] },
  { links: learnLinks },
  { links: toolLinks },
];

const mobileGroupsWithActive = mobileGroups.map((group) => ({
  links: group.links.map((link) => ({ ...link, active: isActive(link.href) })),
}));
---

<div class="sticky top-0 z-50 backdrop-blur-md bg-[var(--bg-primary)]/80 border-b border-slate-mid/20">
  <nav class="flex items-center justify-between px-6 py-4 max-w-5xl mx-auto">
    <a href="/" class="font-display text-3xl italic text-ember shrink-0">Praxis</a>

    <!-- Desktop: static HTML, zero JS -->
    <div class="hidden lg:flex items-center gap-6">
      <a
        href="/#coach"
        class="text-sm font-medium text-slate-light hover:text-ivory transition-colors border border-slate-mid rounded-full px-5 py-2"
      >
        Coach
      </a>
      {allLinks.map((link) => (
        <a
          href={link.href}
          class={`text-sm transition-colors ${
            isActive(link.href)
              ? "text-ember font-semibold"
              : "text-slate-light hover:text-ivory"
          }`}
        >
          {link.label}
        </a>
      ))}
      {user ? (
        <form method="POST" action="/api/v1/auth/logout">
          <button type="submit" class="text-sm text-slate-light hover:text-ivory transition-colors">Logout</button>
        </form>
      ) : (
        <a href="/login" class="text-sm text-slate-light hover:text-ivory transition-colors">Login</a>
      )}
      <ThemeToggle client:load />
    </div>

    <!-- Mobile: islands only where interactivity is needed -->
    <div class="flex items-center gap-3 lg:hidden">
      <ThemeToggle client:load />
      <MobileMenu client:idle groups={mobileGroupsWithActive} user={user ? { id: user.id, email: user.email } : undefined} />
    </div>
  </nav>
</div>
